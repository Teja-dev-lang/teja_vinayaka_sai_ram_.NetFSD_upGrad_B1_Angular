<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MovieHub</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Inter', sans-serif;
                background: linear-gradient(135deg, #020617, #0f172a);
                color: #e2e8f0;
            }

            /* NAVBAR */
            .navbar {
                background: rgba(15, 23, 42, 0.9);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid #1e293b;
            }

            .navbar-brand {
                font-weight: 700;
                font-size: 1.5rem;
                color: #38bdf8 !important;
            }

            .nav-link {
                color: #cbd5f5 !important;
                margin-left: 20px;
                transition: 0.3s;
            }

                .nav-link:hover {
                    color: #38bdf8 !important;
                    transform: scale(1.05);
                }

            /* HERO SECTION */
            .hero {
                padding: 40px 20px;
                border-radius: 15px;
                background: linear-gradient(120deg, #1e293b, #020617);
                margin-bottom: 30px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.6);
            }

                .hero h1 {
                    font-weight: 600;
                }

                .hero p {
                    color: #94a3b8;
                }

            /* CARD CONTAINER */
            .main-container {
                margin-top: 20px;
            }

            .card-box {
                background: rgba(30, 41, 59, 0.8);
                padding: 25px;
                border-radius: 15px;
                backdrop-filter: blur(6px);
                box-shadow: 0 8px 25px rgba(0,0,0,0.7);
            }

            /* FOOTER */
            footer {
                margin-top: 50px;
                padding: 15px;
                background: #020617;
                color: #64748b;
            }
    </style>
</head>

<body>

    <!-- 🔷 NAVBAR -->
    <nav class="navbar navbar-expand-lg px-4">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Movie" asp-action="Index">
                🎬 MovieHub
            </a>

            <div class="ms-auto">
                <a class="nav-link d-inline" asp-controller="Movie" asp-action="Index">
                    <i class="bi bi-film"></i> Movies
                </a>
                <a class="nav-link d-inline" asp-controller="Movie" asp-action="Create">
                    <i class="bi bi-plus-circle"></i> Add Movie
                </a>
            </div>
        </div>
    </nav>

    <!-- 🔶 HERO -->
    <div class="container">
        <div class="hero">
            <h1>🎬 Discover & Manage Movies</h1>
            <p>Track your favorite movies, manage collections, and explore cinema like a pro.</p>
        </div>
    </div>

    <!-- 🔶 MAIN CONTENT -->
    <div class="container main-container">
        <div class="card-box">
            @RenderBody()
        </div>
    </div>

    <!-- 🔻 FOOTER -->
    <footer class="text-center">
        <p>© 2026 MovieHub • Designed with precision</p>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>